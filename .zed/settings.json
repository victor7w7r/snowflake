{
  "lsp": {
    "nixd": {
      "binary": {
        "path": "/run/current-system/sw/bin/nixd",
      },
      "initialization_options": {
        "formatting": {
          "command": ["nixfmt"],
        },
      },
    },
  },

  "languages": {
    "Nix": {
      "formatter": "language_server",
      "format_on_save": "on",
      "language_servers": ["nixd"],
      "tab_size": 2,
    },
  },
}
