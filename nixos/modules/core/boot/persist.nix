        ".config/Seafile"
        ".config/sops"
        ".config/vlc"
        ".config/zen"
        ".local/share/baloo"
        ".local/share/cod"
        ".local/share/containers"
        ".local/share/com.vixalien.sticky"
        ".local/share/emacs"
        ".local/share/JetBrains"
        ".local/share/klipper"
        ".local/share/krdc"
