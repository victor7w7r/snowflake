{ username, ... }:
{
  environment.persistence."/nix/persist" = {
    hideMounts = true;
    directories = [
      "/etc/NetworkManager/system-connections"
      "/etc/nixos"
      "/etc/asusd"
      "/etc/hhd"
      "/var/log/"
      "/var/lib/bluetooth"
      "/var/lib/chrony"
      "/var/lib/containers"
      "/var/lib/fail2ban"
      "/var/lib/lastlog"
      "/var/lib/libvirt"
      "/var/lib/lxc"
